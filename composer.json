{
    "name": "mavidasnc/wp-alpinebits-reservation",
    "description": "WordPress plugin per l'integrazione con l'API AlpineBits Gateway (sendReservation)",
    "type": "wordpress-plugin",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "yahnis-elsts/plugin-update-checker": "^5.4"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcsstandards/phpcsutils": "^1.0",
        "phpcsstandards/phpcsextra": "^1.2",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Mavida\\AlpineBitsReservation\\": "src/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist",
        "fix": "phpcbf --standard=phpcs.xml.dist"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
